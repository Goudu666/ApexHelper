<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!--
        ApexHelper traditional Java Web project.
        Runtime target: Tomcat 9, javax.servlet, JSP, JSTL, JDBC, MySQL.
        This project intentionally does not use Maven, Spring, Spring Boot, or MyBatis.
    -->

    <display-name>ApexHelper</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <filter>
        <filter-name>LoginFilter</filter-name>
        <filter-class>com.apex.filter.LoginFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>LoginFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.apex.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.apex.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.apex.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UserHomeServlet</servlet-name>
        <servlet-class>com.apex.servlet.UserHomeServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LegendListServlet</servlet-name>
        <servlet-class>com.apex.servlet.LegendListServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>WeaponListServlet</servlet-name>
        <servlet-class>com.apex.servlet.WeaponListServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>NoteListServlet</servlet-name>
        <servlet-class>com.apex.servlet.NoteListServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>NoteAddServlet</servlet-name>
        <servlet-class>com.apex.servlet.NoteAddServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>NoteEditServlet</servlet-name>
        <servlet-class>com.apex.servlet.NoteEditServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>NoteDeleteServlet</servlet-name>
        <servlet-class>com.apex.servlet.NoteDeleteServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>PlayerSearchServlet</servlet-name>
        <servlet-class>com.apex.servlet.PlayerSearchServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>com.apex.servlet.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AdminUserListServlet</servlet-name>
        <servlet-class>com.apex.servlet.AdminUserListServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AdminLogListServlet</servlet-name>
        <servlet-class>com.apex.servlet.AdminLogListServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LegendDetailServlet</servlet-name>
        <servlet-class>com.apex.servlet.LegendDetailServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UserHomeServlet</servlet-name>
        <url-pattern>/user/home</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LegendListServlet</servlet-name>
        <url-pattern>/legend/list</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LegendDetailServlet</servlet-name>
        <url-pattern>/legend/detail</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>WeaponListServlet</servlet-name>
        <url-pattern>/weapon/list</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>NoteListServlet</servlet-name>
        <url-pattern>/note/list</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>NoteAddServlet</servlet-name>
        <url-pattern>/note/add</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>NoteEditServlet</servlet-name>
        <url-pattern>/note/edit</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>NoteDeleteServlet</servlet-name>
        <url-pattern>/note/delete</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PlayerSearchServlet</servlet-name>
        <url-pattern>/stat/search</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AdminUserListServlet</servlet-name>
        <url-pattern>/admin/users</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AdminLogListServlet</servlet-name>
        <url-pattern>/admin/logs</url-pattern>
    </servlet-mapping>
</web-app>
